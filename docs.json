{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "cto.new | Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "https://cto.new/"
        },
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://docs.cto.new"
        },
        {
          "anchor": "Changelog",
          "icon": "edit",
          "href": "https://docs.cto.new/changelog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "pages": [
          "introduction",
          {
            "group": "Essentials",
            "pages": [
              {
                "group": "Projects",
                "expanded": true,
                "pages": [
                  "blank-project",
                  "web-app",
                  "open-claw",
                  "mobile-apps"
                ]
              },
              "essentials/repos"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/API",
              "integrations/MCP",
              "integrations/cto-MCP"
            ]
          },
          {
            "group": "Settings & Config",
            "pages": [
              "settings-config/models",
              "settings-config/workspace-settings",
              "settings-config/repo-settings",
              "settings-config/vm",
              "settings-config/setup-agent",
              "settings-config/env-vars",
              "settings-config/prompt-memory",
              "settings-config/teams"
            ]
          },
          "support",
          "fair-use",
          "pricing",
          "privacy",
          "soc2"
        ]
      },
      {
        "tab": "Changelog",
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@enginelabs.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open cto.new",
      "href": "https://cto.new"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/ctodotnew",
      "github": "https://github.com/engine-labs",
      "linkedin": "https://www.linkedin.com/company/enginelabs",
      "discord": "https://discord.gg/cto"
    }
  }
}
